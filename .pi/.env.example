# pi-coding-agent kit — environment variables
#
# Copy this file to `.env` in your project root and fill in any values you need.
# Most features work out-of-the-box; only set these if you want to customize.

# ─── Optional: External research tools (Exa AI) ──────────────────────────────────
# If unset, the default public rate limits apply.
# Get a key at https://exa.ai
# EXA_API_KEY=

# ─── Optional: pi-dcp tuning ─────────────────────────────────────────────────────
# Override the default context-pruning thresholds from @davecodes/pi-dcp
# DCP_DEDUP_ENABLED=true
# DCP_ERROR_PURGE_AFTER=3
# DCP_COMPRESS_TRIGGER_TOKENS=50000

# ─── Optional: pi-vcc (compaction) ───────────────────────────────────────────────
# pi-vcc auto-compacts when context exceeds threshold
# PI_VCC_THRESHOLD=0.85

# ─── Optional: pi-subagents ──────────────────────────────────────────────────────
# Limit parallel subagent count
# PI_SUBAGENT_MAX_PARALLEL=5

# ─── Required: None ──────────────────────────────────────────────────────────────
# This kit works without any environment variables. All built-in tools
# (semantic_*, websearch, codesearch, context7, web_fetch) use public APIs
# or no auth. Only set the above if you want to override defaults.
