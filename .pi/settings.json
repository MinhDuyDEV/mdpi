{
  "$schema": "https://pi.dev/schema/settings.json",
  "packages": [
    "npm:@tintinweb/pi-subagents",
    "npm:@sting8k/pi-srcwalk",
    "npm:@sting8k/pi-vcc",
    "npm:pi-rtk-optimizer",
    "npm:@davecodes/pi-dcp",
    "npm:@eko24ive/pi-ask"
  ],
  "extensions": [
    "./extensions/workflows-runner.ts",
    "./extensions/templates-injector.ts",
    "./extensions/memory.ts",
    "./extensions/skill-manage.ts",
    "./extensions/session-search.ts",
    "./extensions/context-optimizer.ts"
  ],
  "skills": ["./skills"],
  "prompts": ["./prompts"],
  "enableSkillCommands": true,
  "defaultThinkingLevel": "high",
  "powerline": {
    "preset": "nerd"
  }
}
